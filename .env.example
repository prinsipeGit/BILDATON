NODE_ENV=development
PORT=3000
# Supabase runtime connection. Use the Session pooler (port 5432) for this
# long-running API, or Transaction pooler (port 6543) for serverless hosting.
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Supabase direct connection used only by Prisma migrations and schema tools.
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Comma-separated browser origins allowed to call public read-only API endpoints.
CORS_ALLOWED_ORIGINS=https://prinsipegit.github.io,http://localhost:4173
META_APP_SECRET=replace-me
META_VERIFY_TOKEN=replace-me
META_PAGE_ACCESS_TOKEN=replace-me
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
ADMIN_DASHBOARD_TOKEN=replace-with-a-long-random-secret-before-deploying
