generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserKind {
  STAFF
  SYSTEM_ADMIN
}

enum ConversationChannel {
  MESSENGER
  WEB
}

enum SenderKind {
  STUDENT
  STAFF
  AI
  SYSTEM
}

enum TicketStatus {
  NEW
  NEEDS_INFORMATION
  VERIFIED
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_STUDENT
  RESOLVED
  CLOSED
  REOPENED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProcessingStatus {
  RECEIVED
  QUEUED
  PROCESSING
  SUCCEEDED
  RETRYABLE_FAILURE
  PERMANENT_FAILURE
}

enum KnowledgeStatus {
  DRAFT
  FOR_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

model Institution {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  slug           String         @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  departments    Department[]
  users          User[]
  students       Student[]
  conversations  Conversation[]
  tickets        Ticket[]
  webhookEvents  WebhookEvent[]
  auditLogs      AuditLog[]
  knowledgeDocs  KnowledgeDocument[]
}

model Department {
  id            String                 @id @default(uuid()) @db.Uuid
  institutionId String                 @db.Uuid
  name          String
  slug          String
  enabled       Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  institution   Institution            @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  memberships   DepartmentMembership[]
  tickets       Ticket[]
  knowledgeDocs KnowledgeDocument[]

  @@unique([institutionId, slug])
  @@index([institutionId, enabled])
}

model User {
  id             String                 @id @default(uuid()) @db.Uuid
  institutionId  String                 @db.Uuid
  externalAuthId String
  email          String
  kind           UserKind
  active         Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  institution    Institution            @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  staffProfile   StaffProfile?
  memberships    DepartmentMembership[]
  assignedTickets Ticket[]              @relation("TicketAssignee")
  internalNotes  InternalNote[]

  @@unique([institutionId, externalAuthId])
  @@unique([institutionId, email])
}

model StaffProfile {
  id          String @id @default(uuid()) @db.Uuid
  userId      String @unique @db.Uuid
  displayName String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DepartmentMembership {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid
  departmentId String     @db.Uuid
  role         String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([departmentId, role])
}

model Student {
  id                String              @id @default(uuid()) @db.Uuid
  institutionId     String              @db.Uuid
  externalStudentId String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  institution       Institution         @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  messengerIds      MessengerIdentity[]
  verifications     StudentVerification[]
  conversations     Conversation[]

  @@unique([institutionId, externalStudentId])
}

model MessengerIdentity {
  id               String                @id @default(uuid()) @db.Uuid
  institutionId    String                @db.Uuid
  pageId           String
  senderId         String
  studentId        String?               @db.Uuid
  linkedAt         DateTime?
  createdAt        DateTime              @default(now())
  student          Student?              @relation(fields: [studentId], references: [id], onDelete: SetNull)
  conversations    Conversation[]
  verifications    StudentVerification[]

  @@unique([institutionId, pageId, senderId])
  @@index([studentId])
}

model StudentVerification {
  id                  String            @id @default(uuid()) @db.Uuid
  studentId           String            @db.Uuid
  messengerIdentityId String            @db.Uuid
  method              String
  verifiedAt          DateTime
  expiresAt           DateTime
  revokedAt           DateTime?
  student             Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  messengerIdentity   MessengerIdentity @relation(fields: [messengerIdentityId], references: [id], onDelete: Cascade)

  @@index([messengerIdentityId, expiresAt])
}

model Conversation {
  id                  String                @id @default(uuid()) @db.Uuid
  institutionId       String                @db.Uuid
  studentId           String?               @db.Uuid
  messengerIdentityId String?               @db.Uuid
  channel             ConversationChannel
  status              String                @default("OPEN")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  institution         Institution           @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  student             Student?              @relation(fields: [studentId], references: [id], onDelete: SetNull)
  messengerIdentity   MessengerIdentity?    @relation(fields: [messengerIdentityId], references: [id], onDelete: SetNull)
  messages            Message[]
  tickets             Ticket[]

  @@index([institutionId, channel, updatedAt])
  @@index([messengerIdentityId])
}

model Message {
  id                String       @id @default(uuid()) @db.Uuid
  conversationId    String       @db.Uuid
  providerMessageId String?
  senderKind        SenderKind
  content           String
  sentAt            DateTime
  createdAt         DateTime     @default(now())
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, providerMessageId])
  @@index([conversationId, sentAt])
}

model Ticket {
  id              String          @id @default(uuid()) @db.Uuid
  institutionId   String          @db.Uuid
  conversationId  String          @db.Uuid
  departmentId    String          @db.Uuid
  assigneeUserId  String?         @db.Uuid
  referenceNumber String
  subject         String
  status          TicketStatus    @default(NEW)
  priority        TicketPriority  @default(NORMAL)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  institution     Institution     @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  department      Department      @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  assignee        User?           @relation("TicketAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  statusHistory   TicketStatusEvent[]
  internalNotes   InternalNote[]

  @@unique([institutionId, referenceNumber])
  @@index([departmentId, status, priority])
  @@index([conversationId])
}

model TicketStatusEvent {
  id          String       @id @default(uuid()) @db.Uuid
  ticketId    String       @db.Uuid
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  actorUserId String?      @db.Uuid
  reason      String?
  createdAt   DateTime     @default(now())
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model InternalNote {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @db.Uuid
  authorId  String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
}

model WebhookEvent {
  id              String           @id @default(uuid()) @db.Uuid
  institutionId   String           @db.Uuid
  provider        String
  providerEventId String
  status          ProcessingStatus @default(RECEIVED)
  payload          Json
  attempts         Int              @default(0)
  lastErrorCode    String?
  receivedAt      DateTime          @default(now())
  processedAt     DateTime?
  institution     Institution      @relation(fields: [institutionId], references: [id], onDelete: Restrict)

  @@unique([provider, providerEventId])
  @@index([status, receivedAt])
}

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  institutionId  String      @db.Uuid
  actorType      String
  actorId        String?
  action         String
  resourceType   String
  resourceId     String?
  requestId      String?
  metadata       Json?
  occurredAt     DateTime    @default(now())
  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)

  @@index([institutionId, occurredAt])
  @@index([resourceType, resourceId])
}

model KnowledgeDocument {
  id            String             @id @default(uuid()) @db.Uuid
  institutionId String             @db.Uuid
  departmentId  String             @db.Uuid
  title         String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  institution   Institution        @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  department    Department         @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  versions      KnowledgeVersion[]

  @@index([departmentId, updatedAt])
}

model KnowledgeVersion {
  id            String             @id @default(uuid()) @db.Uuid
  documentId    String             @db.Uuid
  version       Int
  status        KnowledgeStatus    @default(DRAFT)
  content       String
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  authorUserId  String             @db.Uuid
  approverUserId String?           @db.Uuid
  approvedAt    DateTime?
  createdAt     DateTime           @default(now())
  document      KnowledgeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([status, effectiveFrom, effectiveTo])
}

model AiRun {
  id              String   @id @default(uuid()) @db.Uuid
  institutionId   String   @db.Uuid
  conversationId  String?  @db.Uuid
  model            String
  purpose          String
  promptVersion    String
  outcome          String
  rationale        String?
  createdAt        DateTime @default(now())
  completedAt      DateTime?
  toolCalls        AiToolCall[]

  @@index([institutionId, createdAt])
  @@index([conversationId])
}

model AiToolCall {
  id             String   @id @default(uuid()) @db.Uuid
  aiRunId        String   @db.Uuid
  toolName       String
  arguments      Json
  authorized     Boolean
  idempotencyKey String?
  resultCode     String?
  createdAt      DateTime @default(now())
  aiRun          AiRun    @relation(fields: [aiRunId], references: [id], onDelete: Cascade)

  @@unique([toolName, idempotencyKey])
  @@index([aiRunId, createdAt])
}
